{
  "name": "millennium-dawn-docs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"src/content/**/*.md\"",
    "lint:remark": "remark \"src/content/**/*.md\" --frail",
    "check:links": "bun scripts/run_site_python_check.ts scripts/check_site_links.py --site-dir dist",
    "check:og": "bun scripts/run_site_python_check.ts scripts/check_og_images.py --site-dir dist",
    "check:a11y": "python scripts/check_accessibility_basics.py --site-dir dist",
    "check:perf": "python scripts/check_perf_budgets.py --site-dir dist",
    "ci": "bun run lint:md && bun run lint:remark && bun run check && bun run build && bun run check:og && bun run check:links && bun run check:a11y && bun run check:perf"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "image-size": "^2.0.2",
    "katex": "^0.16.38",
    "satori": "^0.25.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "markdownlint-cli2": "^0.21.0",
    "remark-cli": "^12.0.1",
    "remark-directive": "^4.0.0",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "typescript-eslint": "^8.57.0",
    "unist-util-visit": "^5.1.0"
  }
}
