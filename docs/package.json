{
  "name": "millennium-dawn-docs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "migrate:astro": "python scripts/migration/bootstrap_astro_content.py",
    "snapshot:jekyll-urls": "bun scripts/migration/extract-jekyll-urls.mjs",
    "snapshot:astro-urls": "bun scripts/migration/extract-astro-urls.mjs",
    "check:route-parity": "bun scripts/migration/compare-route-parity.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint:md": "markdownlint-cli2 \"src/content/**/*.md\"",
    "lint:remark": "remark \"src/content/**/*.md\" --frail",
    "check:links": "python scripts/check_site_links.py --site-dir dist --baseurl /Millennium-Dawn",
    "check:og": "python scripts/check_og_images.py --site-dir dist --baseurl /Millennium-Dawn",
    "check:a11y": "python scripts/check_accessibility_basics.py --site-dir dist",
    "check:perf": "python scripts/check_perf_budgets.py --site-dir dist",
    "ci": "bun run lint:md && bun run lint:remark && bun run check && bun run build && bun run check:og && bun run check:links && bun run check:a11y && bun run check:perf"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "js-yaml": "^4.1.1",
    "markdownlint-cli2": "^0.21.0",
    "remark-cli": "^12.0.1",
    "remark-directive": "^4.0.0",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "unist-util-visit": "^5.1.0"
  }
}
