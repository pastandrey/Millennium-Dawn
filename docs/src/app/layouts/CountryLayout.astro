---
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import CountryInfobox from "@/entities/country/ui/CountryInfobox.astro";
import { PAGE_TITLE_CLASS } from "@/shared/ui/tailwind";

interface Stat {
  label: string;
  value: string;
}

interface InfoboxGroup {
  section: string;
  stats: Stat[];
}

interface Props {
  title: string;
  description?: string;
  seo?: boolean;
  robots?: string;
  pageId?: string;
  bodyClass?: string;
  canonicalPath: string;
  flagImage?: string;
  infobox: InfoboxGroup[];
  headings?: MarkdownHeading[];
}

const {
  title,
  description,
  seo,
  robots,
  pageId,
  bodyClass,
  canonicalPath,
  flagImage,
  infobox,
  headings = [],
}: Props = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  seo={seo}
  robots={robots}
  pageId={pageId}
  bodyClass={bodyClass}
  canonicalPath={canonicalPath}
  toc="auto"
  headings={headings}
>
  <div class="grid gap-xl desktop:grid-cols-[minmax(0,1fr)_minmax(260px,320px)]">
    <div class="min-w-0">
      <h1 class={PAGE_TITLE_CLASS}>{title}</h1>
      <slot />
    </div>
    <aside class="order-first self-start desktop:order-none desktop:sticky desktop:top-[calc(var(--header-height)+var(--space-md))]">
      <CountryInfobox title={title} flagImage={flagImage} infobox={infobox || []} />
    </aside>
  </div>
</BaseLayout>
