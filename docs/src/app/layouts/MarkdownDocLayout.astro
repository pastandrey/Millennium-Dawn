---
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import { resolveToc } from "@/shared/lib/content-helpers";
import { getEntryBodyClass, getEntryPageId } from "@/shared/lib/content-routes";

interface RoutedEntryLike {
  id: string;
  data: {
    title: string;
    description?: string;
    toc?: "auto" | "off";
    seo?: boolean;
    robots?: string;
    page_id?: string;
    body_class?: string;
  };
}

interface Props {
  entry: RoutedEntryLike;
  canonicalPath: string;
  headings?: MarkdownHeading[];
  toc?: "auto" | "off";
}

const { entry, canonicalPath, headings = [], toc }: Props = Astro.props;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  toc={toc ?? resolveToc(entry.data.toc)}
  seo={entry.data.seo ?? true}
  robots={entry.data.robots}
  bodyClass={getEntryBodyClass(entry)}
  pageId={getEntryPageId(entry)}
  headings={headings}
>
  <slot />
</BaseLayout>
