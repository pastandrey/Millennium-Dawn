---
import BaseLayout from "./BaseLayout.astro";
import { toAbsolute, withBase } from "@/lib/urls";
import { BASE_LINK_CLASS, BODY_TEXT_CLASS } from "@/shared/ui/tailwind";

interface Props {
  title: string;
  fromPath: string;
  toPath: string;
  robots?: string;
}

const { title, fromPath, toPath, robots = "noindex, nofollow" }: Props = Astro.props;
const targetHref = withBase(toPath);
---

<BaseLayout
  title={title}
  canonicalPath={fromPath}
  seo={false}
  robots={robots}
  toc="off"
>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0; url=${targetHref}`} />
    <link rel="canonical" href={toAbsolute(toPath)} />
  </Fragment>
  <p class={BODY_TEXT_CLASS}>
    This page has moved to <a class={BASE_LINK_CLASS} href={targetHref}>{toPath}</a>.
  </p>
</BaseLayout>
