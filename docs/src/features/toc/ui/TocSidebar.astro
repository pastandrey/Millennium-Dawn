---
import type { MarkdownHeading } from "astro";

// Shared imports
import {
  FOCUS_RING_CLASS,
  TOC_BACKDROP_CLASS,
  TOC_NAV_CLASS,
  TOC_PANEL_CLASS,
  TOC_SIDEBAR_CLASS,
  TOC_TOGGLE_CLASS,
} from "@/shared/ui/tailwind";

// Internal slice imports
import { TOC_IDS, TOC_LABELS } from "../lib/config";
import { renderTocHtml } from "../lib/render";

interface Props {
  tocMode?: "auto" | "off";
  headings?: MarkdownHeading[];
}

const { tocMode = "auto", headings = [] }: Props = Astro.props;
const hidden = tocMode === "off";
const tocHtml = hidden ? "" : renderTocHtml(headings);

// FAB toggle: Ensure minimum 44x44 target size for WCAG 2.2 AAA (size-12 = 48x48)
// Close button: Increased size to 44x44 for touch accessibility
const closeButtonClass = [
  "flex size-11 items-center justify-center rounded-md bg-transparent text-text-muted",
  "transition-[color,background-color] duration-200 ease-out",
  "hover:bg-primary-light hover:text-primary wide:hidden",
  FOCUS_RING_CLASS,
].join(" ");
---

<aside class={TOC_SIDEBAR_CLASS} id={TOC_IDS.sidebar} aria-labelledby={TOC_IDS.heading} hidden={hidden}>
  <button
    class={TOC_TOGGLE_CLASS}
    id={TOC_IDS.toggle}
    aria-label={TOC_LABELS.open}
    aria-expanded="false"
    aria-controls={TOC_IDS.panel}
    type="button"
    data-nav-hidden="false"
  >
    <!-- Hamburger icon -->
    <svg class="absolute size-6 transition-[opacity,transform] duration-200 ease-out group-aria-expanded:-rotate-90 group-aria-expanded:scale-75 group-aria-expanded:opacity-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
      <path d="M3 4h18v2H3V4zm0 7h12v2H3v-2zm0 7h18v2H3v-2z"></path>
    </svg>
    <!-- Close/Chevron icon -->
    <svg class="absolute size-6 rotate-90 scale-75 opacity-0 transition-[opacity,transform] duration-200 ease-out group-aria-expanded:rotate-0 group-aria-expanded:scale-100 group-aria-expanded:opacity-100" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.3 5.71a1 1 0 0 0-1.41 0L12 10.59 7.11 5.7A1 1 0 0 0 5.7 7.11L10.59 12 5.7 16.89a1 1 0 1 0 1.41 1.41L12 13.41l4.89 4.89a1 1 0 0 0 1.41-1.41L13.41 12l4.89-4.89a1 1 0 0 0 0-1.4z"></path>
    </svg>
  </button>

  <div
    class={TOC_BACKDROP_CLASS}
    id={TOC_IDS.backdrop}
    aria-hidden="true"
  ></div>

  <div class={TOC_PANEL_CLASS} id={TOC_IDS.panel}>
    <!-- Clean minimalist header with distinct boundaries -->
    <header class="flex items-center justify-between border-b border-border/60 bg-surface px-5 py-4 wide:border-transparent wide:bg-transparent wide:py-2">
      <h2 class="m-0 p-0 text-sm font-semibold tracking-tight text-text" id={TOC_IDS.heading}>{TOC_LABELS.title}</h2>
      <button class={closeButtonClass} id={TOC_IDS.close} aria-label={TOC_LABELS.close} type="button">
        <svg class="size-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.3 5.71a1 1 0 0 0-1.41 0L12 10.59 7.11 5.7A1 1 0 0 0 5.7 7.11L10.59 12 5.7 16.89a1 1 0 1 0 1.41 1.41L12 13.41l4.89 4.89a1 1 0 0 0 1.41-1.41L13.41 12l4.89-4.89a1 1 0 0 0 0-1.4z"></path>
        </svg>
      </button>
    </header>

    <!-- Reading progress indicator -->
    <div class="h-[2px] w-full overflow-hidden bg-border-light/50" aria-hidden="true">
      <div class="h-full w-0 bg-primary transition-[width] duration-150 ease-out" id={TOC_IDS.progress}></div>
    </div>

    <nav
      class={TOC_NAV_CLASS}
      id={TOC_IDS.nav}
      aria-label={TOC_LABELS.nav}
    >
      {tocHtml && <Fragment set:html={tocHtml} />}
    </nav>
  </div>
</aside>

<script>
  import { initTocPage } from "../model/page";

  initTocPage();
</script>
