---
import ArticleFooter from "./ArticleFooter.astro";
import ArticleHero from "./ArticleHero.astro";

interface MetaItem {
  label: string;
  value: string;
  datetime?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  metaItems?: MetaItem[];
  tags?: string[];
  lastUpdated?: Date;
  editUrl?: string;
}

const props: Props = Astro.props;
const { lastUpdated, editUrl } = props;
const shellClass = ["grid", "gap-xl", "min-w-0"].join(" ");
---

<section class={shellClass}>
  <ArticleHero {...props} />
  <article class="min-w-0">
    <slot />
    <ArticleFooter lastUpdated={lastUpdated} editUrl={editUrl} />
  </article>
</section>
