---
import ResponsiveImage from "@/shared/ui/ResponsiveImage.astro";
import { withBase } from "@/lib/urls";
import { getPublicImageDimensions } from "@/shared/lib/public-image-size";
import { getInternalImageAsset } from "@/shared/lib/image-assets";

interface Props {
  src: string;
  alt?: string;
  class?: string;
  width?: number | string;
  height?: number | string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  title?: string;
}

const {
  src,
  alt = "",
  class: className,
  width,
  height,
  loading = "lazy",
  decoding = "async",
  title,
}: Props = Astro.props;

function parseDimension(value: number | string | undefined): number | undefined {
  if (typeof value === "number") return value;
  if (typeof value === "string" && /^\d+$/.test(value)) return Number(value);
  return undefined;
}

const explicitWidth = parseDimension(width);
const explicitHeight = parseDimension(height);
const internalAsset = getInternalImageAsset(src);
const inferredDimensions = explicitWidth && explicitHeight
  ? null
  : internalAsset
    ? { width: internalAsset.width, height: internalAsset.height }
    : await getPublicImageDimensions(src);
const resolvedWidth = explicitWidth ?? inferredDimensions?.width;
const resolvedHeight = explicitHeight ?? inferredDimensions?.height;
const resolvedClassName = className?.trim();
const canUseResponsiveImage = Boolean(resolvedWidth && resolvedHeight);
---

{
  canUseResponsiveImage ? (
    <ResponsiveImage
      src={internalAsset ?? src}
      alt={alt}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      wrapperClass={resolvedClassName}
      class={resolvedClassName}
    />
  ) : (
    <img
      src={withBase(src)}
      alt={alt}
      class={resolvedClassName}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      title={title}
    />
  )
}
