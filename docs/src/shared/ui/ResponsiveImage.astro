---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import { resolveImageSource } from "@/shared/lib/image-assets";

type ImageFormat = "avif" | "webp";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
  /** When true, image is decorative (alt empty) - adds role="presentation" and aria-hidden for accessibility */
  decorative?: boolean;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  sizes?: string;
  width?: number;
  height?: number;
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  wrapperClass?: string;
  formats?: ImageFormat[];
}

const {
  src,
  alt = "",
  decorative = false,
  loading = "lazy",
  decoding = "async",
  sizes = "100vw",
  width,
  height,
  fetchpriority,
  class: className,
  wrapperClass,
  formats = ["avif", "webp"],
}: Props = Astro.props;

const resolvedSrc = resolveImageSource(src);
const pictureClassName = [wrapperClass, "block"].filter(Boolean).join(" ");
const imageClassName = ["h-auto", "max-w-full", "rounded", className].filter(Boolean).join(" ");
const isStringSource = typeof resolvedSrc === "string";
const resolvedWidth = width ?? (isStringSource ? undefined : resolvedSrc.width);
const resolvedHeight = height ?? (isStringSource ? undefined : resolvedSrc.height);

if (!resolvedWidth || !resolvedHeight) {
  throw new Error("ResponsiveImage requires width and height for string sources.");
}

const resolvedAlt = decorative ? "" : alt;
const pictureAttrs = decorative ? { role: "presentation" as const, "aria-hidden": "true" as const } : {};
const pictureAttributes = { class: pictureClassName, ...pictureAttrs };
---

{
  isStringSource ? (
    <Picture
      src={resolvedSrc}
      alt={resolvedAlt}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      sizes={sizes}
      formats={formats}
      layout="constrained"
      class={imageClassName}
      pictureAttributes={pictureAttributes}
    />
  ) : (
    <Picture
      src={resolvedSrc}
      alt={resolvedAlt}
      width={resolvedWidth}
      height={resolvedHeight}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      sizes={sizes}
      formats={formats}
      layout="constrained"
      class={imageClassName}
      pictureAttributes={pictureAttributes}
    />
  )
}
