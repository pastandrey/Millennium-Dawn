---
interface Stat {
  key?: string;
  label: string;
  value: string;
}

interface Props {
  stats: Stat[];
  excludeKeys?: string[];
}

const { stats, excludeKeys = [] }: Props = Astro.props;
const filtered = (stats || []).filter((stat) => !stat.key || !excludeKeys.includes(stat.key));
---

<ul class="m-0 grid list-none gap-[0.4rem] px-4 pb-[0.8rem]">
  {filtered.map((stat) => (
    <li class="m-0 flex items-center justify-between gap-[0.8rem] text-[0.9rem]">
      <span class="text-text-secondary">{stat.label}</span>
      <strong>{stat.value}</strong>
    </li>
  ))}
</ul>
