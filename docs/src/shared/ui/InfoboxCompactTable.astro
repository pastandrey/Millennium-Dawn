---
interface Stat {
  key?: string;
  label: string;
  value: string;
}

interface Group {
  section: string;
  stats: Stat[];
}

interface Column {
  key: string;
  label: string;
}

interface Props {
  group: Group;
  columns: Column[];
  label: string;
}

const { group, columns, label }: Props = Astro.props;

function statValue(key: string): string {
  const match = (group.stats ?? []).find((item) => item.key === key);
  return match?.value ?? "-";
}
---

<div class="px-4 pb-[0.6rem]">
  <table class="w-full table-fixed border-collapse text-center text-[0.76rem] leading-[1.25]" aria-label={label}>
    <thead class="bg-[color-mix(in_srgb,var(--color-surface)_92%,var(--color-primary-light))]">
      <tr>
        {
          columns.map((col) => (
            <th scope="col" class="border border-border-light px-[0.3rem] py-[0.35rem] font-bold text-text-secondary">
              {col.label}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody>
      <tr>
        {
          columns.map((col) => (
            <td class="border border-border-light px-[0.3rem] py-[0.35rem] align-middle">{statValue(col.key)}</td>
          ))
        }
      </tr>
    </tbody>
  </table>
</div>
