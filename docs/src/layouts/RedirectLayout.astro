---
import BaseLayout from "./BaseLayout.astro";
import { toAbsolute, withBase } from "../lib/urls";

interface Props {
  title: string;
  fromPath: string;
  toPath: string;
  robots?: string;
}

const { title, fromPath, toPath, robots = "noindex, nofollow" } = Astro.props;
const targetHref = withBase(toPath);
---

<BaseLayout
  title={title}
  canonicalPath={fromPath}
  seo={false}
  robots={robots}
  toc="off"
>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0; url=${targetHref}`} />
    <link rel="canonical" href={toAbsolute(toPath)} />
  </Fragment>
  <p>
    This page has moved to <a href={targetHref}>{toPath}</a>.
  </p>
</BaseLayout>
