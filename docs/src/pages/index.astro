---
import { getEntry } from "astro:content";
import { BaseLayout } from "@/app/layouts";
import {
  Hero,
  HomeIntro,
  HomeRoadmaps,
  HomeCommunity,
  HomeResourceGroups,
  HomeSubmods,
  HomeCredits,
} from "@/widgets/home";
import { STATIC_PAGE_META } from "@/shared/lib/page-meta";
import { SECTION_TITLE_CLASS } from "@/shared/ui/tailwind";

const releaseEntry = await getEntry("release", "index");
const homeEntry = await getEntry("home", "index");
if (!releaseEntry) {
  throw new Error("Missing release/index data entry");
}
if (!homeEntry) {
  throw new Error("Missing home/index data entry");
}

const release = releaseEntry.data.current;
const home = homeEntry.data;
const pageMeta = STATIC_PAGE_META.home;
const { hero, roadmaps, team_join, paratranz_projects, resource_groups, credits } = home;
---

<BaseLayout
  title={pageMeta.title}
  pageId={pageMeta.pageId}
  canonicalPath={pageMeta.canonicalPath}
  description={pageMeta.description}
  toc="off"
>
  <Hero hero={hero} />

  <div class="flex flex-col gap-10 tablet:gap-14 my-xl [&_h2]:!mt-0">
    <HomeIntro release={release} />
    <HomeRoadmaps roadmaps={roadmaps} />

    <section aria-labelledby="community-resources-heading">
      <h2 id="community-resources-heading" class:list={[SECTION_TITLE_CLASS, "mb-6"]}>Community & Resources</h2>
      <div class="flex flex-col gap-10 tablet:gap-14">
        <HomeCommunity teamJoinDescription={team_join.description} paratranzProjects={paratranz_projects} />

        <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-md">
          <HomeResourceGroups groups={resource_groups} />
        </div>

        <HomeSubmods />
      </div>
    </section>

    <HomeCredits credits={credits} />
  </div>
</BaseLayout>
