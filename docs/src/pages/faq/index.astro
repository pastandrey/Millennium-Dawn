---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveToc } from "../../lib/content-helpers";

const entry = await getEntry("pages", "faq");
if (!entry) {
  throw new Error("Missing pages/faq content entry");
}

const { Content, headings } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath="/faq/"
  toc={resolveToc(entry.data.toc)}
  seo={entry.data.seo ?? true}
  robots={entry.data.robots}
  pageId={entry.data.page_id || "faq"}
  headings={headings}
>
  <Content />
</BaseLayout>
