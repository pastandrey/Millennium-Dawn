---
import { getEntry } from "astro:content";
import { BaseLayout } from "@/app/layouts";
import { withBase } from "@/lib/urls";
import { STATIC_PAGE_META } from "@/lib/page-meta";
import { BASE_LINK_CLASS, BODY_TEXT_CLASS, INLINE_CODE_CLASS, LIST_CLASS, LIST_ITEM_CLASS, PAGE_TITLE_CLASS, SECTION_TITLE_CLASS } from "@/shared/ui/tailwind";

const releaseEntry = await getEntry("release", "index");
if (!releaseEntry) {
  throw new Error("Missing release/index data entry");
}

const release = releaseEntry.data.current;
const links = releaseEntry.data.links;
const pageMeta = STATIC_PAGE_META.support;
---

<BaseLayout
  title={pageMeta.title}
  description={pageMeta.description}
  canonicalPath={pageMeta.canonicalPath}
  pageId={pageMeta.pageId}
  toc="off"
>
  <h1 class={PAGE_TITLE_CLASS}>Technical Support</h1>

  <p class={BODY_TEXT_CLASS}>
    For the full <a class={BASE_LINK_CLASS} href={withBase("/player-tutorials/troubleshooting-guide/")}>Troubleshooting Guide</a>.
  </p>

  {release && (
    <>
      <p class={BODY_TEXT_CLASS}>
        Current MD Version: <code class={INLINE_CODE_CLASS}>{release.md_version}</code>
      </p>
      <p class={BODY_TEXT_CLASS}>
        HOI Version: <code class={INLINE_CODE_CLASS}>{release.hoi_version}</code>
      </p>
      <p class={BODY_TEXT_CLASS}>
        Checksum: <code class={INLINE_CODE_CLASS}>{release.checksum}</code>
      </p>
    </>
  )}

  <h2 class={SECTION_TITLE_CLASS}>Downloads and References</h2>
  <ul class={LIST_CLASS}>
    {links &&
      Object.values(links).map((item) => (
        <li class={LIST_ITEM_CLASS}>
          <a class={BASE_LINK_CLASS} href={item.url}>{item.label}</a>
        </li>
      ))}
  </ul>
</BaseLayout>
