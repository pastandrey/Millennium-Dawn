---
import { BaseLayout } from "@/app/layouts";
import { withBase } from "@/shared/lib/urls";
import { BODY_TEXT_CLASS, BUTTON_PRIMARY_CLASS, SECTION_TITLE_CLASS } from "@/shared/ui/tailwind";
---

<BaseLayout
  title="Page Not Found"
  canonicalPath="/404.html"
  seo={false}
  robots="noindex, nofollow, noarchive"
  pageId="404"
  toc="off"
>
  <div class="py-16 text-center">
    <h1 class="mb-2 border-b-0 pb-0 text-[4rem] font-bold leading-none text-text">404</h1>
    <h2 class={SECTION_TITLE_CLASS}>Page Not Found</h2>
    <p class={`${BODY_TEXT_CLASS} mx-auto max-w-[40rem]`}>
      The page you are looking for does not exist or has been moved.
    </p>
    <p class="mb-0">
      <a href={withBase("/")} class={BUTTON_PRIMARY_CLASS}>Return to Home</a>
    </p>
  </div>
</BaseLayout>
