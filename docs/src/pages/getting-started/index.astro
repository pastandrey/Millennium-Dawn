---
import { getEntry, render } from "astro:content";
import { MarkdownDocLayout } from "@/app/layouts";
import { CONTENT_PAGE_ROUTES } from "@/shared/lib/page-meta";
import MarkdownContent from "@/shared/ui/MarkdownContent.astro";

const entry = await getEntry("pages", "getting-started");
if (!entry) {
  throw new Error("Missing pages/getting-started content entry");
}

const { Content, headings } = await render(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={CONTENT_PAGE_ROUTES["getting-started"]} headings={headings}>
  <MarkdownContent Content={Content} />
</MarkdownDocLayout>
