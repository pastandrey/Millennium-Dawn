---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import { DevDiaryLayout } from "@/app/layouts";
import DevDiaryArticleShell from "@/entities/dev-diary/ui/DevDiaryArticleShell.astro";
import { getDevDiaryPath, getDevDiarySlug } from "@/shared/lib/content-routes";
import { buildMarkdownDocStaticPaths, renderMarkdownDocEntry } from "@/shared/lib/markdown-doc-entry";
import MarkdownContent from "@/shared/ui/MarkdownContent.astro";

interface Props {
  entry: CollectionEntry<"devDiaries">;
}

export const getStaticPaths: GetStaticPaths = async () => {
  return buildMarkdownDocStaticPaths("devDiaries", getDevDiarySlug);
};

const { entry }: Props = Astro.props;
const { Content, headings } = await renderMarkdownDocEntry(entry);
---

<DevDiaryLayout entry={entry} canonicalPath={getDevDiaryPath(entry)} headings={headings}>
  <DevDiaryArticleShell entry={entry}>
    <MarkdownContent Content={Content} />
  </DevDiaryArticleShell>
</DevDiaryLayout>
