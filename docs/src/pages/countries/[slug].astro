---
import { getCollection, render } from "astro:content";
import CountryLayout from "../../layouts/CountryLayout.astro";
import { stripMarkdownExt } from "../../lib/slugs";

export async function getStaticPaths() {
  const entries = await getCollection("countries");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug || stripMarkdownExt(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const countrySlug = entry.data.slug || stripMarkdownExt(entry.id);
---

<CountryLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/countries/${countrySlug}/`}
  pageId={entry.data.page_id || stripMarkdownExt(entry.id)}
  flagImage={entry.data.flag_image}
  infobox={entry.data.infobox || []}
  headings={headings}
>
  <Content />
</CountryLayout>
