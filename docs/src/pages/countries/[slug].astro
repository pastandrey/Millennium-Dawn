---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import { CountryLayout } from "@/app/layouts";
import {
  buildEntryStaticPaths,
  getCountryPath,
  getCountrySlug,
  getEntryBodyClass,
  getEntryPageId,
} from "@/shared/lib/content-routes";
import MarkdownContent from "@/shared/ui/MarkdownContent.astro";

interface Props {
  entry: CollectionEntry<"countries">;
}

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection("countries");
  return buildEntryStaticPaths(entries, getCountrySlug);
};

const { entry }: Props = Astro.props;
const { Content, headings } = await render(entry);
---

<CountryLayout
  title={entry.data.title}
  description={entry.data.description}
  seo={entry.data.seo ?? true}
  robots={entry.data.robots}
  canonicalPath={getCountryPath(entry)}
  pageId={getEntryPageId(entry)}
  bodyClass={getEntryBodyClass(entry)}
  flagImage={entry.data.flag_image}
  infobox={entry.data.infobox ?? []}
  headings={headings}
>
  <MarkdownContent Content={Content} />
</CountryLayout>
