---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import { MarkdownDocLayout } from "@/app/layouts";
import { getArticleFooterProps } from "@/shared/lib/article-footer-props";
import { getTutorialHeroProps } from "@/shared/lib/article-hero-props";
import { getEntryBaseId, getTutorialPath } from "@/shared/lib/content-routes";
import { buildMarkdownDocStaticPaths, renderMarkdownDocEntry } from "@/shared/lib/markdown-doc-entry";
import ArticleShell from "@/shared/ui/ArticleShell.astro";
import MarkdownContent from "@/shared/ui/MarkdownContent.astro";

interface Props {
  entry: CollectionEntry<"tutorials">;
}

export const getStaticPaths: GetStaticPaths = async () => {
  return buildMarkdownDocStaticPaths("tutorials", getEntryBaseId);
};

const { entry }: Props = Astro.props;
const { Content, headings } = await renderMarkdownDocEntry(entry);
const heroProps = getTutorialHeroProps(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={getTutorialPath(entry)} headings={headings}>
  <ArticleShell {...heroProps} {...getArticleFooterProps(entry)}>
    <MarkdownContent Content={Content} />
  </ArticleShell>
</MarkdownDocLayout>
