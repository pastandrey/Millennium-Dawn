---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import { MarkdownDocLayout } from "@/app/layouts";
import { getEntryBaseId, getMiscPath } from "@/lib/content-routes";
import { buildMarkdownDocStaticPaths, renderMarkdownDocEntry } from "@/lib/markdown-doc-entry";
import MarkdownContent from "@/shared/ui/MarkdownContent.astro";

interface Props {
  entry: CollectionEntry<"misc">;
}

export const getStaticPaths: GetStaticPaths = async () => {
  return buildMarkdownDocStaticPaths("misc", getEntryBaseId);
};

const { entry }: Props = Astro.props;
const { Content, headings } = await renderMarkdownDocEntry(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={getMiscPath(entry)} headings={headings}>
  <MarkdownContent Content={Content} />
</MarkdownDocLayout>
