---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { resolveToc } from "../../lib/content-helpers";
import { stripMarkdownExt } from "../../lib/slugs";

export async function getStaticPaths() {
  const entries = await getCollection("misc");
  return entries.map((entry) => ({
    params: { slug: stripMarkdownExt(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/misc/${stripMarkdownExt(entry.id)}/`}
  toc={resolveToc(entry.data.toc)}
  seo={entry.data.seo ?? true}
  robots={entry.data.robots}
  pageId={entry.data.page_id || stripMarkdownExt(entry.id)}
  headings={headings}
>
  <Content />
</BaseLayout>
