---
import { withBase } from "@/lib/urls";
import { BASE_LINK_CLASS } from "@/shared/ui/tailwind";

interface SectionMeta {
  title: string;
  url: string;
}

interface Props {
  path: string;
  title?: string;
  sections?: Record<string, SectionMeta>;
}

const { path, title, sections = {} }: Props = Astro.props;
const segments = (path || "/")
  .split("/")
  .filter(Boolean)
  .filter((segment) => segment !== "index.html");
---

{
  segments.length > 1 && (
    <nav class="py-md text-sm text-text-muted print:hidden" aria-label="Breadcrumb">
      <ol class="m-0 flex flex-wrap items-center gap-xs p-0 list-none">
        <li class="m-0 flex items-center gap-xs text-sm text-text-muted">
          {/* Increase touch target padding on touch devices without affecting visual size layout strongly */}
          <a class={`${BASE_LINK_CLASS} py-1`} href={withBase("/")} aria-label="Home">
            Home
          </a>
        </li>
        {
          segments.map((segment, index) => {
            const isLast = index === segments.length - 1;
            const section = sections[segment];
            const segmentPath = `/${segments.slice(0, index + 1).join("/")}/`;
            const segmentTitle = section?.title || segment.replace(/-/g, " ").replace(/\b\w/g, (m) => m.toUpperCase());
            const segmentHref = section?.url || segmentPath;

            if (isLast) {
              return (
                <li class="m-0 flex items-center gap-xs text-sm text-text-muted before:mr-xs before:text-text-muted before:content-['/']">
                  <span class="py-1" aria-current="page">{title ?? segmentTitle}</span>
                </li>
              );
            }

            return (
              <li class="m-0 flex items-center gap-xs text-sm text-text-muted before:mr-xs before:text-text-muted before:content-['/']">
                {/* Increase touch target padding */}
                <a class={`${BASE_LINK_CLASS} py-1`} href={withBase(segmentHref)} aria-label={segmentTitle}>
                  {segmentTitle}
                </a>
              </li>
            );
          })
        }
      </ol>
    </nav>
  )
}
