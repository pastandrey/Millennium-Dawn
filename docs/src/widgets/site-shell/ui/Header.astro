---
import { Image } from "astro:assets";
import mainMenuLogo from "@/assets/images/branding/main-menu.png";
import { ensureTrailingSlash, withBase } from "@/shared/lib/urls";
import { LAYOUT_CONTAINER_CLASS, SITE_HEADER_CLASS, FOCUS_RING_CLASS } from "@/shared/ui/tailwind";

interface NavItem {
  title: string;
  url: string;
}

interface Props {
  title: string;
  navItems: NavItem[];
  currentPath: string;
}

const { title, navItems, currentPath }: Props = Astro.props;

function normalize(path: string): string {
  return ensureTrailingSlash(path.replace(/index\.html$/, ""));
}

const current = normalize(currentPath || "/");

const navLinkClass = [
  "inline-flex",
  "min-h-11",
  "min-w-11",
  "items-center",
  "justify-center",
  "rounded",
  "px-md",
  "text-[0.95rem]",
  "leading-[1.2]",
  "text-text-secondary",
  "font-medium",
  "no-underline",
  "transition-[background-color,color,box-shadow]",
  "duration-[var(--transition-speed)]",
  "ease-[var(--transition-fn)]",
  "hover:text-primary",
  "hover:bg-primary-light/50",
  "hover:no-underline",
  "tabletOnly:px-sm",
  "tabletOnly:text-[0.875rem]",
  "mobile:h-auto",
  "mobile:w-full",
  "mobile:justify-start",
  "mobile:rounded-none",
  "mobile:px-md",
  "mobile:py-md",
  "mobile:text-left",
  "mobile:whitespace-normal",
  FOCUS_RING_CLASS,
].join(" ");

const navToggleClass = [
  "nav-toggle",
  "hidden",
  "min-h-11",
  "min-w-11", // Ensure minimum 44x44 target size for WCAG 2.2 AAA
  "items-center",
  "justify-center",
  "rounded",
  "border-2",
  "border-border-light",
  "bg-transparent",
  "p-sm",
  "text-text-secondary",
  "transition-[border-color,color]",
  "duration-[var(--transition-speed)]",
  "ease-[var(--transition-fn)]",
  "hover:border-border",
  "hover:text-text",
  "mobile:flex",
  "[&[aria-expanded=true]>svg:first-of-type]:hidden",
  "[&[aria-expanded=true]>svg:last-of-type]:block",
  FOCUS_RING_CLASS,
].join(" ");

const themeButtonClass = [
  "dark-mode-button",
  "flex",
  "size-11", // Ensure minimum 44x44 target size for WCAG 2.2 AAA (size-11 = 44px)
  "shrink-0",
  "items-center",
  "justify-center",
  "rounded-full",
  "border-2",
  "border-transparent",
  "bg-transparent",
  "text-text-secondary",
  "transition-[background-color,color,transform]",
  "duration-[var(--transition-speed)]",
  "ease-[var(--transition-fn)]",
  "hover:bg-surface-hover",
  "hover:text-primary",
  "hover:scale-105",
  "active:scale-95",
  "focus-visible:bg-surface-active",
  FOCUS_RING_CLASS,
].join(" ");
---

<header class={SITE_HEADER_CLASS}>
  <div class={LAYOUT_CONTAINER_CLASS}>
    <div class="w-full">
      <div class="flex w-full items-center justify-between gap-md mobile:flex-wrap mobile:gap-y-sm">
        <div class="shrink-0">
          <a href={withBase("/")} aria-label={title}>
            <Image
              src={mainMenuLogo}
              alt={title}
              class="h-11 w-auto"
              width={246}
              height={143}
              loading="eager"
              fetchpriority="high"
            />
            <span class="sr-only">Homepage</span>
          </a>
        </div>

        <nav
          class="main-nav order-3 w-full overflow-hidden max-h-0 opacity-0 transition-[max-height,opacity,transform] duration-nav ease-in-out mobile:flex-[1_0_100%] mobile:-translate-y-1 mobile:[&.is-open]:max-h-[540px] mobile:[&.is-open]:opacity-100 mobile:[&.is-open]:translate-y-0 mobile:[&.is-closing]:pointer-events-none tablet:order-none tablet:flex-[1_1_auto] tablet:min-w-0 tablet:overflow-visible tablet:max-h-none tablet:opacity-100"
          id="main-nav"
          aria-label="Main navigation"
        >
          <ul
            class="m-0 flex min-h-11 flex-col items-stretch justify-center gap-0 p-0 tablet:flex-row tablet:flex-wrap tablet:items-center tablet:justify-center tablet:gap-sm"
          >
            {
              navItems.map((item) => {
                const itemPath = normalize(item.url || "/");
                const isSectionActive = itemPath !== "/" && current.startsWith(itemPath);
                const isActive = current === itemPath || isSectionActive;
                return (
                  <li>
                    <a
                      href={withBase(item.url)}
                      class:list={[
                        navLinkClass,
                        isActive &&
                          "text-primary bg-primary-light/40 shadow-[inset_0_0_0_1px_var(--color-primary-light)] font-semibold",
                      ]}
                      aria-current={isActive ? "page" : undefined}
                    >
                      {item.title}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>

        <div class="ml-auto flex shrink-0 items-center gap-sm">
          <button
            class={navToggleClass}
            aria-label="Open navigation menu"
            aria-expanded="false"
            aria-controls="main-nav"
            type="button"
          >
            <svg class="size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M3 4h18v2H3V4zm0 7h18v2H3v-2zm0 7h18v2H3v-2z" fill="currentColor"></path>
            </svg>
            <svg class="hidden size-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path
                d="M18.3 5.71a1 1 0 0 0-1.41 0L12 10.59 7.11 5.7A1 1 0 0 0 5.7 7.11L10.59 12 5.7 16.89a1 1 0 1 0 1.41 1.41L12 13.41l4.89 4.89a1 1 0 0 0 1.41-1.41L13.41 12l4.89-4.89a1 1 0 0 0 0-1.4z"
                fill="currentColor"></path>
            </svg>
          </button>

          <button class={themeButtonClass} aria-label="Toggle dark mode" aria-pressed="false" type="button">
            <svg
              class="size-5 [html.dark-mode_&]:hidden"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 18a6 6 0 1 1 0-12 6 6 0 0 1 0 12zm0-2a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM11 1h2v3h-2V1zm0 19h2v3h-2v-3zM3.515 4.929l1.414-1.414L7.05 5.636 5.636 7.05 3.515 4.93zM16.95 18.364l1.414-1.414 2.121 2.121-1.414 1.414-2.121-2.121zm2.121-14.85l1.414 1.415-2.121 2.121-1.414-1.414 2.121-2.121zM5.636 16.95l1.414 1.414-2.121 2.121-1.414-1.414 2.121-2.121zM23 11v2h-3v-2h3zM4 11v2H1v-2h3z"
              ></path>
            </svg>
            <svg
              class="hidden size-5 [html.dark-mode_&]:block"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M10 7a7 7 0 0 0 12 4.9v.1c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2h.1A6.979 6.979 0 0 0 10 7zm-6 5a8 8 0 0 0 15.062 3.762A9 9 0 0 1 8.238 4.938 7.999 7.999 0 0 0 4 12z"
              ></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>
