---
import type { ImageMetadata } from "astro";
import ResponsiveImage from "@/shared/ui/ResponsiveImage.astro";
import {
  BODY_TEXT_CLASS,
  PANEL_SURFACE_CLASS,
  SECTION_TITLE_CLASS,
  SUBSECTION_TITLE_CLASS,
} from "@/shared/ui/tailwind";

interface RoadmapImage {
  src: string | ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
}

interface Roadmap {
  title: string;
  paragraphs?: string[];
  image: RoadmapImage;
}

interface Props {
  roadmaps: Roadmap[];
}

const { roadmaps }: Props = Astro.props;
---

<section aria-labelledby="roadmaps-heading" class="flex flex-col gap-lg">
  <h2 id="roadmaps-heading" class={SECTION_TITLE_CLASS}>Roadmap Images</h2>
  {
    roadmaps.map((roadmap) => (
      <article class:list={[PANEL_SURFACE_CLASS, "p-lg"]}>
        <h3 class={SUBSECTION_TITLE_CLASS}>{roadmap.title}</h3>
        {(roadmap.paragraphs ?? []).map((paragraph) => (
          <p class={BODY_TEXT_CLASS}>{paragraph}</p>
        ))}
        <ResponsiveImage
          src={roadmap.image.src}
          alt={roadmap.image.alt}
          width={roadmap.image.width}
          height={roadmap.image.height}
          loading={roadmap.image.loading}
          wrapperClass="mt-sm overflow-hidden rounded-lg border border-border-light"
          class="w-full"
        />
      </article>
    ))
  }
</section>
