---
import { getImage } from "astro:assets";
import heroImage from "@/assets/images/branding/hero.jpeg";
import { cssUrl, withBase } from "@/lib/urls";
import {
  BUTTON_OUTLINE_CLASS,
  BUTTON_PRIMARY_CLASS,
  BUTTON_SECONDARY_CLASS,
  FOCUS_RING_CLASS,
} from "@/shared/ui/tailwind";

interface HeroLink {
  label: string;
  url: string;
}

interface HeroNote {
  prefix: string;
  link_label: string;
  link_url: string;
  suffix?: string;
}

interface HeroContent {
  badge: HeroLink;
  title: string;
  subtitle: string;
  primary_cta: HeroLink;
  secondary_cta: HeroLink;
  community_cta: HeroLink;
  note: HeroNote;
}

interface Props {
  hero: HeroContent;
}

const { hero }: Props = Astro.props;

const optimizedHero = await getImage({
  src: heroImage,
  format: "webp",
  quality: 80,
  width: 1920,
});

const heroNoteLinkClass = [
  "text-text-secondary",
  "underline",
  "decoration-border",
  "underline-offset-4",
  "transition-colors",
  "duration-[var(--transition-speed)]",
  "ease-[var(--transition-fn)]",
  "hover:text-primary",
  "hover:decoration-primary",
  "py-1", // Increases the touch target size slightly for inline links
  FOCUS_RING_CLASS,
].join(" ");
---

<section class="relative mb-xl flex min-h-[480px] items-center justify-center overflow-hidden rounded-lg bg-surface border border-border-light px-container py-2xl text-center text-text shadow-lg">
  <div
    class="absolute inset-0 bg-[image:var(--hero-bg)] bg-cover bg-center opacity-[0.08] mix-blend-luminosity [html.dark-mode_&]:opacity-[0.15]"
    style={`--hero-bg: ${cssUrl(optimizedHero.src)};`}
    aria-hidden="true"
  ></div>
  <div class="relative z-[1] mx-auto flex max-w-[800px] flex-col items-center">
    <a
      href={withBase(hero.badge.url)}
      class:list={[
        "mb-lg inline-flex items-center gap-sm rounded-full border border-border bg-surface px-md py-sm text-sm font-semibold text-text shadow-sm no-underline [backdrop-filter:blur(12px)] hover:border-primary hover:text-primary hover:no-underline transition-colors",
        "min-h-11", // Add a min-height for target size
        FOCUS_RING_CLASS,
      ]}
    >
      <span class="size-2 rounded-full bg-info" aria-hidden="true"></span> {hero.badge.label}
    </a>

    <h1 class="mb-md text-[clamp(2rem,5vw+1rem,3.5rem)] font-bold leading-[1.1] text-text" id="hero-heading">
      {hero.title}
    </h1>
    <p class="mb-xl max-w-[90%] text-[clamp(1.1rem,2vw+0.5rem,1.25rem)] leading-[1.65] text-text-secondary">
      {hero.subtitle}
    </p>

    <div class="flex flex-wrap justify-center gap-md mobile:w-full mobile:flex-col mobile:items-stretch" aria-labelledby="hero-heading">
      <a href={withBase(hero.primary_cta.url)} class={BUTTON_PRIMARY_CLASS}>{hero.primary_cta.label}</a>
      <a href={withBase(hero.secondary_cta.url)} class={BUTTON_SECONDARY_CLASS}>{hero.secondary_cta.label}</a>
      <a href={withBase(hero.community_cta.url)} class={BUTTON_OUTLINE_CLASS} target="_blank" rel="noopener noreferrer">
        {hero.community_cta.label}
      </a>
    </div>

    <p class="mb-sm mt-md text-[0.95rem] text-text-secondary">
      {hero.note.prefix} <a class={heroNoteLinkClass} href={withBase(hero.note.link_url)}>{hero.note.link_label}</a>
      {hero.note.suffix && ` ${hero.note.suffix}`}
    </p>
  </div>
</section>
