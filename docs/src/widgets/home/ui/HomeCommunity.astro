---
import InlineMarkdownText from "@/shared/ui/InlineMarkdownText.astro";
import {
  SUBSECTION_TITLE_CLASS,
  TRANSLATION_LINK_CLASS,
  TRANSLATION_LIST_CLASS,
} from "@/shared/ui/tailwind";

interface ParatranzProject {
  name: string;
  url: string;
}

interface Props {
  teamJoinDescription?: string;
  paratranzProjects: ParatranzProject[];
}

const { teamJoinDescription, paratranzProjects }: Props = Astro.props;
---

<section aria-labelledby="joining-team-heading">
  <h3 id="joining-team-heading" class={SUBSECTION_TITLE_CLASS}>Joining the Millennium Dawn Development Team</h3>
  {teamJoinDescription && <InlineMarkdownText text={teamJoinDescription} />}
</section>

<section aria-labelledby="translations-heading">
  <h3 id="translations-heading" class={SUBSECTION_TITLE_CLASS}>Translations</h3>
  <h4 class="mb-sm text-sm font-semibold uppercase tracking-wider text-text-muted">Paratranz Projects</h4>
  <p class="mb-sm text-xs text-text-muted">Links open in a new tab.</p>
  <ul class={TRANSLATION_LIST_CLASS}>
    {paratranzProjects.map((project) => (
      <li>
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class={TRANSLATION_LINK_CLASS}
        >
          {project.name}
        </a>
      </li>
    ))}
  </ul>
</section>
