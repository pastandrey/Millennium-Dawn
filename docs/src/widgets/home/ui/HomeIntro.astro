---
import { SECTION_TITLE_CLASS, PANEL_SURFACE_CLASS } from "@/shared/ui/tailwind";

interface ReleaseSummary {
  md_version: string;
  checksum: string;
}

interface Props {
  release?: ReleaseSummary;
}

const { release }: Props = Astro.props;
---

<section aria-labelledby="intro-heading" class="flex flex-col gap-6">
  <h2 id="intro-heading" class={SECTION_TITLE_CLASS}>Welcome to the MD Wiki</h2>

  {release && (
    <div class:list={[PANEL_SURFACE_CLASS, "flex flex-col tablet:flex-row tablet:items-center gap-6 p-6"]}>
      <div class="flex-1">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-1">Current Expected Version</h3>
        <p class="text-2xl font-bold text-text">{release.md_version}</p>
      </div>
      <div class="hidden tablet:block w-px self-stretch bg-border-light"></div>
      <div class="flex-1">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-1">Current Expected Checksum</h3>
        <p class="text-2xl font-bold font-mono text-text">{release.checksum}</p>
      </div>
    </div>
  )}

  <div class="rounded-lg bg-primary/5 border border-primary/20 p-5">
    <p class="text-sm text-text-secondary leading-relaxed flex items-start gap-3 m-0">
      <svg class="size-5 text-primary shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
      <span>
        <strong class="font-semibold text-text">Note:</strong> The following Wiki is currently a work in progress. However, we will do our best to get meaningful content updated and placed on this page.
      </span>
    </p>
  </div>
</section>

