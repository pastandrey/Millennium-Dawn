---
import type { CollectionEntry } from "astro:content";
import { getArticleFooterProps } from "@/shared/lib/article-footer-props";
import ArticleShell from "@/shared/ui/ArticleShell.astro";

interface Props {
  entry: CollectionEntry<"devDiaries">;
}
const { entry } = Astro.props;
const publishedDate = entry.data.date;
const publishedLabel = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  month: "short",
  year: "numeric",
}).format(publishedDate);
const tags = entry.data.tags ?? [];

const heroProps = {
  eyebrow: "Millennium Dawn Dev Diary",
  title: entry.data.title,
  description: entry.data.description,
  metaItems: [
    { label: "Author", value: entry.data.author },
    { label: "Published", value: publishedLabel, datetime: publishedDate.toISOString() },
  ],
  tags: tags.length > 0 ? tags : undefined,
};
---

<ArticleShell {...heroProps} {...getArticleFooterProps(entry)}>
  <slot />
</ArticleShell>
