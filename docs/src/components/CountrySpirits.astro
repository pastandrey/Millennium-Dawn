---
interface Spirit {
  name: string;
  type?: string;
  desc?: string;
}

interface Props {
  items: Spirit[];
}

const { items } = Astro.props;
---

<ul class="spirits-list" role="list">
  {(items || []).map((spirit) => (
    <li class={`spirit spirit--${spirit.type || "neutral"}`} role="listitem">
      <span class="spirit__indicator" aria-hidden="true"></span>
      <span class="spirit__name">{spirit.name}</span>
      {spirit.desc && <span class="spirit__desc">{spirit.desc}</span>}
    </li>
  ))}
</ul>
