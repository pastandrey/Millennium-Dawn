---
import { withBase } from "../lib/urls";

interface LinkItem {
  title: string;
  url: string;
}

interface SocialItem {
  name: string;
  url: string;
}

interface Props {
  siteTitle: string;
  siteDescription: string;
  footerDocs: LinkItem[];
  socialLinks: SocialItem[];
}

const { siteTitle, siteDescription, footerDocs, socialLinks } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>{siteTitle}</h3>
        <p>{siteDescription}</p>
      </div>

      <div class="footer-section" aria-label="Social links">
        <h3>Links</h3>
        <ul>
          {socialLinks.map((item) => (
            <li>
              <a href={item.url} target="_blank" rel="noopener noreferrer" aria-label={item.name}>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-section" aria-label="Documentation links">
        <h3>Documentation</h3>
        <ul>
          {footerDocs.map((item) => (
            <li>
              <a href={withBase(item.url)} aria-label={item.title}>
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {siteTitle}. All rights reserved.</p>
    </div>
  </div>
</footer>
