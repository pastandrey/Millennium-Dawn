---
import { Image } from "astro:assets";
import { withBase } from "../lib/urls";

interface Props {
  src: string;
  alt?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  sizes?: string;
  srcset?: string;
  width: number;
  height: number;
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  wrapperClass?: string;
  avif?: string;
  webp?: string;
}

const {
  src,
  alt = "",
  loading = "lazy",
  decoding = "async",
  sizes = "100vw",
  srcset,
  width,
  height,
  fetchpriority,
  class: className,
  wrapperClass,
  avif,
  webp,
} = Astro.props;
---

<picture class={wrapperClass}>
  {avif && <source srcset={withBase(avif)} type="image/avif" sizes={sizes} />}
  {webp && <source srcset={withBase(webp)} type="image/webp" sizes={sizes} />}
  <Image
    src={withBase(src)}
    alt={alt}
    sizes={srcset ? sizes : undefined}
    width={width}
    height={height}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    class={className}
  />
</picture>
