---
import { getImage } from "astro:assets";
import heroImage from "../../assets/images/branding/hero.jpeg";
import { cssUrl, withBase } from "../lib/urls";

const optimizedHero = await getImage({
  src: heroImage,
  format: "webp",
  quality: 80,
  width: 1920,
});
---

<section class="hero-section">
  <div class="hero-background" style={`--hero-bg: ${cssUrl(optimizedHero.src)};`}></div>
  <div class="hero-content">
    <a href={withBase("/changelogs/")} class="hero-badge">
      <span class="badge-dot"></span> See latest updates
    </a>

    <h1 class="hero-title">Welcome to Millennium Dawn</h1>
    <p class="hero-subtitle">
      With the dawn of a new millennium, a new chapter in human history will be written. Immerse yourself in the intricacies of
      the modern era with unique tech trees, a complex economic system, and deep political mechanics.
    </p>

    <div class="hero-actions">
      <a href={withBase("/getting-started/")} class="btn btn-primary">Getting Started</a>
      <a href={withBase("/countries/")} class="btn btn-secondary">Playable Countries</a>
      <a href="https://discord.gg/millenniumdawn" class="btn btn-outline" target="_blank" rel="noopener">Join Discord</a>
    </div>

    <p class="hero-note">
      See the <a href={withBase("/player-tutorials/troubleshooting-guide/")}>Troubleshooting Guide</a> for common issues.
    </p>
  </div>
</section>
