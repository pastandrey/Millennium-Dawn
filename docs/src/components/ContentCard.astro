---
interface Props {
  title: string;
  url?: string;
  kind?: string;
  description?: string;
  meta?: string;
}

const { title, url, kind, description, meta } = Astro.props;
---

<div class="content-card">
  {kind && <p class="content-card__kind">{kind}</p>}

  <h3 class="content-card__title">
    {url ? <a href={url}>{title}</a> : <span>{title}</span>}
  </h3>

  {description && <p class="content-card__description">{description}</p>}
  {meta && <p class="content-card__meta">{meta}</p>}
</div>
