---
import { withBase } from "../lib/urls";

interface SectionMeta {
  title: string;
  url: string;
}

interface Props {
  path: string;
  title?: string;
  sections?: Record<string, SectionMeta>;
}

const { path, title, sections = {} } = Astro.props;
const segments = (path || "/")
  .split("/")
  .filter(Boolean)
  .filter((segment) => segment !== "index.html");

if (segments.length <= 1) {
  // Breadcrumbs are hidden for top-level routes.
}
---

{
  segments.length > 1 && (
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li>
          <a href={withBase("/")} aria-label="Home">
            Home
          </a>
        </li>
        {
          segments.map((segment, index) => {
            const isLast = index === segments.length - 1;
            const section = sections[segment];
            const segmentPath = `/${segments.slice(0, index + 1).join("/")}/`;
            const segmentTitle = section?.title || segment.replace(/-/g, " ").replace(/\b\w/g, (m) => m.toUpperCase());
            const segmentHref = section?.url || segmentPath;

            if (isLast) {
              return (
                <li>
                  <span aria-current="page">{title || segmentTitle}</span>
                </li>
              );
            }

            return (
              <li>
                <a href={withBase(segmentHref)} aria-label={segmentTitle}>
                  {segmentTitle}
                </a>
              </li>
            );
          })
        }
      </ol>
    </nav>
  )
}
